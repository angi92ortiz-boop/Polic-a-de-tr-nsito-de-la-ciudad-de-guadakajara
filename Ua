función local GetClosestToFOV()
    objetivo local, más cercano = nil, Combat_Settings.FOV
    centro local = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    para _, p en ipairs(Players:GetPlayers()) hacer
        Si p ~= LocalPlayer y p.Character entonces
            local char = p.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            
            si hum and head and hum.Health > 0 entonces
                posición local, en pantalla = Cámara:Punto del mundo a la ventana gráfica(cabeza.Posición)
                si está en pantalla entonces
                    distancia local = (Vector2.new(pos.X, pos.Y) - centro).Magnitud
                    si dist < más cercano entonces
                        más cercano = distancia
                        objetivo = p
                    fin
                fin
            fin
        fin
    fin
    objetivo de retorno
fin

