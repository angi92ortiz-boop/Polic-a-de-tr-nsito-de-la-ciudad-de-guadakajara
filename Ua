-- [ SISTEMA DRAG INTERACTIVO SUAVE ]
función local HacerArrastrable(obj)
    arrastre local, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        Si input.UserInputType == Enum.UserInputType.MouseButton1 o input.UserInputType == Enum.UserInputType.Touch entonces
            arrastrando = verdadero
            dragStart = input.Position
            startPos = obj.Position
        fin
    fin)
    InputService.InputChanged:Connect(function(input)
        si se está arrastrando y (input.UserInputType == Enum.UserInputType.MouseMovement o input.UserInputType == Enum.UserInputType.Touch) entonces
            delta local = input.Position - dragStart
            TweenService:Create(obj, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
                Posición = dim2(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Jugar()
        fin
    fin)
    InputService.InputEnded:Connect(function(input)
        Si input.UserInputType == Enum.UserInputType.MouseButton1 o input.UserInputType == Enum.UserInputType.Touch entonces
            arrastrando = falso
        fin
    fin)
fin

