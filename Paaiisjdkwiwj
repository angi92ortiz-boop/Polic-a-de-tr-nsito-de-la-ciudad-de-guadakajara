                t.Button.TextColor3 = themes.deselected
                t.Page.Visible = false 
            end
            TabButton.TextColor3 = themes.accent
            Page.Visible = true
        end)

        table.insert(Library.Tabs, { Button = TabButton, Page = Page })
        if #Library.Tabs == 1 then 
            TabButton.TextColor3 = themes.accent
            Page.Visible = true 
        end
        return Page
    end

    function Library:AddToggle(page, text, callback)
        local Tgl = Instance.new("TextButton")
        Tgl.Size = dim2(1, -10, 0, 35)
        Tgl.BackgroundColor3 = rgb(30, 32, 32)
        Tgl.Text = "  " .. text
        Tgl.TextColor3 = rgb(200, 200, 200)
        Tgl.Font = Enum.Font.SourceSans
        Tgl.TextSize = 14
        Tgl.TextXAlignment = Enum.TextXAlignment.Left
        Tgl.Parent = page

        local state = false
        Tgl.MouseButton1Click:Connect(function() 
            state = not state
            Tgl.TextColor3 = state and themes.accent or rgb(200, 200, 200)
            callback(state) 
        end)
        Instance.new("UICorner", Tgl).CornerRadius = dim(0, 4)
    end

    function Library:AddSlider(page, text, min, max, callback)
        local frame = Instance.new("Frame")
        frame.Size = dim2(1, -10, 0, 45)
        frame.BackgroundTransparency = 1
        frame.Parent = page

        local label = Instance.new("TextLabel")
        label.Size = dim2(1, 0, 0, 20)
        label.Text = text
        label.TextColor3 = themes.white
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.SourceSans
        label.TextSize = 14
        label.Parent = frame

        local bar = Instance.new("TextButton")
        bar.Size = dim2(1, 0, 0, 10)
        bar.Position = dim2(0, 0, 0, 22)
        bar.BackgroundColor3 = rgb(40, 40, 40)
        bar.Text = ""
        bar.Parent = frame

        local fill = Instance.new("Frame")
        fill.Size = dim2(0.2, 0, 1, 0)
        fill.BackgroundColor3 = themes.accent
        fill.Parent = bar

        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                local move
                move = InputService.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
                        local p = math.clamp((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                        fill.Size = dim2(p, 0, 1, 0)
                        callback(math.floor(min + (max - min) * p))
                    end
                end)
                local release
                release = InputService.InputEnded:Connect(function(i) 
                    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then 
                        move:Disconnect()
                        release:Disconnect()
                    end 
                end)
            end
        end)
    end
    
    function Library:AddButton(page, text, callback)
        local Btn = Instance.new("TextButton")
        Btn.Size = dim2(1, -10, 0, 35)
        Btn.BackgroundColor3 = rgb(30, 32, 32)
        Btn.Text = text
        Btn.TextColor3 = themes.white
        Btn.Font = Enum.Font.SourceSansBold
        Btn.TextSize = 14
        Btn.Parent = page

        Btn.MouseButton1Click:Connect(callback)
        Instance.new("UICorner", Btn).CornerRadius = dim(0, 4)
    end

    return Library
end

