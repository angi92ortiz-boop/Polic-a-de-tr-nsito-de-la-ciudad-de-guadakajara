local function GetClosestToFOV()
    local target, closest = nil, Combat_Settings.FOV
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            local head = char:FindFirstChild("Head")
            
            if hum and head and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < closest then 
                        closest = dist
                        target = p 
                    end
                end
            end
        end
    end
    return target
end

-- [ UNIFICACIÓN DE METAMÉTODOS (Previene desbordamiento de pila) ]
if hookmetamethod then
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local args = { ... }
        local method = getnamecallmethod()
        
        if not checkcaller() then
            if method == "FireServer" and Combat_Settings.SilentAim then
                local target = GetClosestToFOV()
                if target and target.Character and target.Character:FindFirstChild("Head") then
                    for i, arg in ipairs(args) do
                        if typeof(arg) == "Vector3" then 
                            args[i] = target.Character.Head.Position 
                        end
                    end
                end
            end
        end
        return oldNamecall(self, unpack(args))
    end)
end

-- [ DISEÑO DE INTERFAZ Y EFECTOS ]
local function CreateGalaxy(parent)
    local canvas = Instance.new("Frame")
    canvas.Size = dim2(1, 0, 1, 0)
    canvas.BackgroundTransparency = 1
    canvas.ClipsDescendants = true
    canvas.Parent = parent

    local stars = {}
    for i = 1, 45 do -- Reducido de 65 a 45 para optimizar ciclos de renderizado
        local star = Instance.new("Frame")
        star.Size = dim2(0, math.random(1, 2), 0, math.random(1, 2))
        star.Position = dim2(math.random(), 0, math.random(), 0)
        star.BackgroundColor3 = themes.white
        star.BorderSizePixel = 0
        star.Parent = canvas
        table.insert(stars, { frame = star, speed = math.random(6, 14) / 1000 })
    end

    RunService.Heartbeat:Connect(function()
        for _, s in ipairs(stars) do
            local nY = s.frame.Position.Y.Scale + s.speed
            if nY > 1 then nY = -0.02 end
            s.frame.Position = dim2(s.frame.Position.X.Scale, 0, nY, 0)
        end
    end)
end

local function ApplySplitEffect(obj)
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, themes.white),
        ColorSequenceKeypoint.new(0.5, themes.white),
        ColorSequenceKeypoint.new(0.501, themes.accent),
        ColorSequenceKeypoint.new(1, themes.accent)
    })
    grad.Parent = obj
end

local function ApplyShadowBorder(obj)
    local Glow = Instance.new("ImageLabel")
    Glow.BackgroundTransparency = 1
    Glow.Position = dim2(0, -15, 0, -15)
    Glow.Size = dim2(1, 30, 1, 30)
    Glow.ZIndex = obj.ZIndex - 1
    Glow.Image = "rbxassetid://5028857084"
    Glow.ScaleType = Enum.ScaleType.Slice
    Glow.SliceCenter = Rect.new(24, 24, 276, 276)
    Glow.Parent = obj
    ApplySplitEffect(Glow)

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1.8
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Color = themes.white
    stroke.Parent = obj
    ApplySplitEffect(stroke)
end

local function MakeDraggable(obj)
    local dragging, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
        end
    end)
    InputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            obj.Position = dim2(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    InputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            dragging = false 
        end 
    end)
end

-- [ GESTIÓN Y LIMPIEZA DEL ESP ]
local function CreateESP(player)
    if player == LocalPlayer then return end

    local objects = {
        Box = Drawing.new("Square"),
        HealthBar = Drawing.new("Line"),
        Tracer = Drawing.new("Line"),
        NameTag = Drawing.new("Text")
    }

    objects.Box.Color = themes.white
    objects.Box.Thickness = 1
    objects.Box.Filled = false
    
    objects.HealthBar.Color = rgb(0, 255, 0)
    objects.HealthBar.Thickness = 2
    
    objects.Tracer.Color = themes.white
    objects.Tracer.Thickness = 1
    
    objects.NameTag.Color = themes.white
    objects.NameTag.Center = true
    objects.NameTag.Outline = true
    objects.NameTag.Size = 14

    ESP_Cache[player] = objects

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChildOfClass("Humanoid") then
            local char = player.Character
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChildOfClass("Humanoid")
            
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen and hum.Health > 0 then
                local sizeY = (Camera:WorldToViewportPoint(root.Position + Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0)).Y)
                local boxSize = Vector2.new(sizeY / 1.5, sizeY)
                local boxPos = Vector2.new(pos.X - boxSize.X / 2, pos.Y - boxSize.Y / 2)

                objects.Box.Visible = ESP_Settings.Box
                objects.Box.Size = boxSize
                objects.Box.Position = boxPos

                objects.HealthBar.Visible = ESP_Settings.Health
                local healthPercent = hum.Health / hum.MaxHealth
                objects.HealthBar.From = Vector2.new(boxPos.X - 7, boxPos.Y + boxSize.Y)
                objects.HealthBar.To = Vector2.new(boxPos.X - 7, boxPos.Y + boxSize.Y - (boxSize.Y * healthPercent))

                objects.NameTag.Visible = ESP_Settings.Names
                objects.NameTag.Text = player.Name
                objects.NameTag.Position = Vector2.new(pos.X, boxPos.Y - 15)

                if ESP_Settings.Tracers and GetClosestToFOV() == player and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") then
                    local myHeadPos = Camera:WorldToViewportPoint(LocalPlayer.Character.Head.Position)
                    objects.Tracer.Visible = true
                    objects.Tracer.From = Vector2.new(myHeadPos.X, myHeadPos.Y)
                    objects.Tracer.To = Vector2.new(pos.X, pos.Y)
                else 
                    objects.Tracer.Visible = false 
                end
            else
                for _, obj in pairs(objects) do obj.Visible = false end
            end
        else
            for _, obj in pairs(objects) do obj.Visible = false end
        end
    end)

    ESP_Cache[player].Connection = connection
end

local function RemoveESP(player)
    if ESP_Cache[player] then
        if ESP_Cache[player].Connection then 
            ESP_Cache[player].Connection:Disconnect() 
        end
        for _, obj in pairs(ESP_Cache[player]) do
            if typeof(obj) ~= "RBXScriptConnection" then 
                obj:Remove() 
            end
        end
        ESP_Cache[player] = nil
    end
end

for _, p in ipairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)

